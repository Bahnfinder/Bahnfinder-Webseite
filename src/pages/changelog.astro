---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

const fullChangelogUrl = "https://raw.githubusercontent.com/Bahnfinder/Changelog/main/Bahnfinder%20Changelog.md";
---


<Layout title="Changelog">
  <Container>
    <Sectionhead>
    <Fragment slot="title">
      <span class="BFGradient">Changelog</span>
    </Fragment>  
          <Fragment slot="desc">
        Bahnfinder wird mit jedem Update besser. Hier findest du die neuesten Features, Verbesserungen und andere Neuigkeiten.
      </Fragment>
    </Sectionhead>

    <section
      id="full-changelog-panel"
      class="full-changelog-panel max-w-4xl mx-auto mt-12"
      data-url={fullChangelogUrl}>
      <div
        id="full-changelog-status"
        class="secondaryLabelColor px-1 py-3">
        Changelog wird geladen ...
      </div>
      <article
        id="full-changelog-content"
        class="full-changelog-content prose prose-lg max-w-none hidden">
      </article>
    </section>
  </Container>
</Layout>

<script>
  const panel = document.querySelector("#full-changelog-panel");
  const status = document.querySelector("#full-changelog-status");
  const content = document.querySelector("#full-changelog-content");

  let hasLoadedFullChangelog = false;

  function escapeHtml(value) {
    return value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function renderInlineMarkdown(value) {
    const escaped = escapeHtml(value);

    return escaped
      .replace(/`([^`]+)`/g, "<code>$1</code>")
      .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
      .replace(/__([^_]+)__/g, "<strong>$1</strong>")
      .replace(/\*([^*]+)\*/g, "<em>$1</em>")
      .replace(/_([^_]+)_/g, "<em>$1</em>")
      .replace(/\[([^\]]+)\]\((https?:\/\/[^)\s]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
  }

  function markdownToHtml(markdown) {
    const lines = markdown.replace(/\r\n?/g, "\n").split("\n");
    const html = [];
    let listOpen = false;

    function closeList() {
      if (listOpen) {
        html.push("</ul>");
        listOpen = false;
      }
    }

    for (const line of lines) {
      const trimmed = line.trim();

      if (!trimmed) {
        closeList();
        continue;
      }

      const heading = trimmed.match(/^(#{1,6})\s+(.+)$/);
      if (heading) {
        closeList();
        const level = Math.min(heading[1].length + 1, 6);
        html.push(`<h${level}>${renderInlineMarkdown(heading[2])}</h${level}>`);
        continue;
      }

      if (/^[-*_]{3,}$/.test(trimmed)) {
        closeList();
        html.push("<hr>");
        continue;
      }

      const listItem = trimmed.match(/^[-*]\s+(.+)$/);
      if (listItem) {
        if (!listOpen) {
          html.push("<ul>");
          listOpen = true;
        }
        html.push(`<li>${renderInlineMarkdown(listItem[1])}</li>`);
        continue;
      }

      closeList();
      html.push(`<p>${renderInlineMarkdown(trimmed)}</p>`);
    }

    closeList();

    return html.join("");
  }

  async function loadFullChangelog() {
    if (!panel || !status || !content || hasLoadedFullChangelog) {
      return;
    }

    const url = panel.getAttribute("data-url");
    if (!url) {
      return;
    }

    try {
      const response = await fetch(url, { cache: "no-store" });
      if (!response.ok) {
        throw new Error(`GitHub hat mit Status ${response.status} geantwortet.`);
      }

      const markdown = await response.text();
      content.innerHTML = markdownToHtml(markdown);
      status.classList.add("hidden");
      content.classList.remove("hidden");
      hasLoadedFullChangelog = true;
    } catch (error) {
      const message = error instanceof Error ? error.message : "Unbekannter Fehler";
      status.textContent = `Der vollständige Changelog konnte nicht geladen werden. ${message}`;
    }
  }

  loadFullChangelog();
</script>

<style>
  .full-changelog-content {
    padding: 0;
  }

  .full-changelog-content :global(h2),
  .full-changelog-content :global(h3),
  .full-changelog-content :global(h4) {
    background-image: linear-gradient(
      to bottom right,
      var(--BFGradientStart),
      var(--BFGradientEnd)
    );
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }

  .full-changelog-content :global(a) {
    color: #60a5fa;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .full-changelog-content :global(hr) {
    border-color: rgb(255 255 255 / 0.1);
  }

  .full-changelog-content :global(ul) {
    padding-left: 1.25rem;
  }
</style>
